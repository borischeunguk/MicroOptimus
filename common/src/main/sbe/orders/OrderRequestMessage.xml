<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="com.microoptimus.common.sbe.orders"
                   id="1"
                   version="1"
                   semanticVersion="1.0"
                   description="Order routing messages - Zero-JNI SBE architecture"
                   byteOrder="littleEndian">

    <types>
        <composite name="messageHeader" description="Message identifiers and length of message root">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <composite name="groupSizeEncoding" description="Repeating group dimensions">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="numInGroup" primitiveType="uint16"/>
        </composite>

        <type name="symbol" primitiveType="char" length="16" description="Fixed-length symbol"/>

        <enum name="Side" encodingType="uint8">
            <validValue name="BUY">0</validValue>
            <validValue name="SELL">1</validValue>
        </enum>

        <enum name="OrderType" encodingType="uint8">
            <validValue name="MARKET">0</validValue>
            <validValue name="LIMIT">1</validValue>
            <validValue name="STOP">2</validValue>
            <validValue name="STOP_LIMIT">3</validValue>
        </enum>

        <enum name="Algorithm" encodingType="uint8">
            <validValue name="SIMPLE">1</validValue>
            <validValue name="TWAP">2</validValue>
            <validValue name="VWAP">3</validValue>
            <validValue name="POV">4</validValue>
            <validValue name="ICEBERG">5</validValue>
        </enum>

        <enum name="RoutingAction" encodingType="uint8">
            <validValue name="ROUTE_EXTERNAL">0</validValue>
            <validValue name="ROUTE_INTERNAL">1</validValue>
            <validValue name="SPLIT_ORDER">2</validValue>
            <validValue name="REJECT">3</validValue>
        </enum>

        <enum name="VenueId" encodingType="uint8">
            <validValue name="INTERNAL">1</validValue>
            <validValue name="CME">2</validValue>
            <validValue name="NASDAQ">3</validValue>
            <validValue name="NYSE">4</validValue>
            <validValue name="ARCA">5</validValue>
            <validValue name="IEX">6</validValue>
        </enum>
    </types>

    <sbe:message name="OrderRequest" id="1" description="Order routing request for zero-JNI SOR communication">
        <field name="sequenceId" id="1" type="uint64" description="Global sequence from Aeron Cluster"/>
        <field name="orderId" id="2" type="uint64" description="Unique order ID"/>
        <field name="symbol" id="3" type="symbol" description="Trading symbol (e.g. AAPL, MSFT)"/>
        <field name="side" id="4" type="Side" description="Buy or Sell"/>
        <field name="orderType" id="5" type="OrderType" description="Market/Limit/Stop"/>
        <field name="price" id="6" type="uint64" description="Price scaled by 1,000,000 (e.g. $15.50 = 15500000)"/>
        <field name="quantity" id="7" type="uint64" description="Order quantity in shares"/>
        <field name="timestamp" id="8" type="uint64" description="Order timestamp in nanoseconds"/>
        <field name="algorithm" id="9" type="Algorithm" description="Routing algorithm selection"/>
        <field name="maxLatencyNanos" id="10" type="uint64" description="Maximum acceptable latency"/>
        <field name="clientId" id="11" type="uint32" description="Client identifier"/>
        <field name="minFillQty" id="12" type="uint64" description="Minimum fill quantity"/>
        <field name="timeInForce" id="13" type="uint8" description="0=IOC, 1=GTC, 2=DAY"/>
    </sbe:message>

    <sbe:message name="RoutingDecision" id="2" description="SOR routing decision response">
        <field name="sequenceId" id="1" type="uint64" description="Matching request sequence"/>
        <field name="orderId" id="2" type="uint64" description="Original order ID"/>
        <field name="action" id="3" type="RoutingAction" description="Routing action taken"/>
        <field name="estimatedFillTime" id="4" type="uint64" description="Expected fill time in nanoseconds"/>
        <field name="totalQuantity" id="5" type="uint64" description="Total routed quantity"/>
        <field name="estimatedFees" id="6" type="uint64" description="Estimated total fees scaled by 1M"/>
        <field name="confidence" id="7" type="uint32" description="Routing confidence 0-100%"/>
        <field name="rejectReason" id="8" type="char" length="64" description="Rejection reason if applicable"/>

        <group name="allocations" id="9" description="Venue allocations">
            <field name="venueId" id="10" type="VenueId" description="Target venue"/>
            <field name="quantity" id="11" type="uint64" description="Allocated quantity"/>
            <field name="priority" id="12" type="uint8" description="Execution priority (1=highest)"/>
            <field name="estimatedLatency" id="13" type="uint64" description="Venue latency in nanoseconds"/>
            <field name="estimatedFees" id="14" type="uint64" description="Venue fees scaled by 1M"/>
            <field name="fillProbability" id="15" type="uint32" description="Fill probability 0-100%"/>
        </group>
    </sbe:message>

    <sbe:message name="OrderRoutingNotification" id="3" description="Lightweight Aeron notification message">
        <field name="sequenceId" id="1" type="uint64" description="Global sequence ID from Aeron"/>
        <field name="orderId" id="2" type="uint64" description="Order ID for correlation"/>
        <field name="messageLength" id="3" type="uint32" description="SBE message length in shared memory"/>
        <field name="bufferOffset" id="4" type="uint64" description="Offset in shared memory buffer"/>
        <field name="templateId" id="5" type="uint16" description="SBE template ID (1=OrderRequest, 2=RoutingDecision)"/>
        <field name="urgency" id="6" type="uint8" description="0=Normal, 1=High, 2=Critical"/>
    </sbe:message>

    <sbe:message name="RoutingResponse" id="4" description="Lightweight SOR response notification">
        <field name="sequenceId" id="1" type="uint64" description="Matching request sequence"/>
        <field name="orderId" id="2" type="uint64" description="Original order ID"/>
        <field name="action" id="3" type="RoutingAction" description="Routing action taken"/>
        <field name="messageLength" id="4" type="uint32" description="Decision message length in bytes"/>
        <field name="bufferOffset" id="5" type="uint64" description="Decision buffer offset"/>
        <field name="processingTime" id="6" type="uint32" description="SOR processing time in nanoseconds"/>
        <field name="venueCount" id="7" type="uint8" description="Number of venues in allocation"/>
    </sbe:message>
</sbe:messageSchema>
